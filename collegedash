<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>College Admin Dashboard</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- FontAwesome for Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        body {
            background-color: #f4f7f6;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        
        /* Navbar styling */
        .navbar {
            background-color: #2c3e50;
        }
        .navbar-brand, .nav-link {
            color: #ecf0f1 !important;
        }
        
        /* Card styling */
        .card {
            border: none;
            border-radius: 10px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
            transition: transform 0.3s ease;
        }
        .card:hover {
            transform: translateY(-5px);
        }
        .icon-box {
            font-size: 2.5rem;
            margin-bottom: 10px;
        }
        
        /* Table container styling */
        .table-container {
            background: white;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
        }
    </style>
</head>
<body>

    <!-- Top Navigation -->
    <nav class="navbar navbar-expand-lg mb-4">
        <div class="container">
            <a class="navbar-brand fw-bold" href="#">
                <i class="fas fa-university me-2"></i> EduAdmin Dashboard
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon" style="filter: invert(1);"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="#"><i class="fas fa-bell"></i> Notifications</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#"><i class="fas fa-user-circle me-1"></i> Admin</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="text-dark m-0">Overview</h3>
            <button class="btn btn-primary"><i class="fas fa-download me-1"></i> Generate Report</button>
        </div>
        
        <!-- KPI Cards -->
        <div class="row g-4 mb-5">
            <div class="col-md-3 col-sm-6">
                <div class="card p-3 text-center">
                    <div class="icon-box text-primary"><i class="fas fa-user-graduate"></i></div>
                    <h6 class="text-muted text-uppercase mb-1">Total Students</h6>
                    <h3 class="fw-bold m-0">4,520</h3>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="card p-3 text-center">
                    <div class="icon-box text-success"><i class="fas fa-chalkboard-teacher"></i></div>
                    <h6 class="text-muted text-uppercase mb-1">Total Faculty</h6>
                    <h3 class="fw-bold m-0">310</h3>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="card p-3 text-center">
                    <div class="icon-box text-warning"><i class="fas fa-book-open"></i></div>
                    <h6 class="text-muted text-uppercase mb-1">Active Courses</h6>
                    <h3 class="fw-bold m-0">85</h3>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="card p-3 text-center">
                    <div class="icon-box text-danger"><i class="fas fa-money-check-alt"></i></div>
                    <h6 class="text-muted text-uppercase mb-1">Fee Collection</h6>
                    <h3 class="fw-bold m-0">$125K</h3>
                </div>
            </div>
        </div>

        <!-- Recent Enrollments Table -->
        <div class="row">
            <div class="col-12">
                <div class="table-container">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="m-0">Recent Admissions</h5>
                        <a href="#" class="text-decoration-none">View All</a>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Roll No</th>
                                    <th>Student Name</th>
                                    <th>Department</th>
                                    <th>Admission Date</th>
                                    <th>Status</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td class="fw-bold">#ST1001</td>
                                    <td>John Doe</td>
                                    <td>Computer Science</td>
                                    <td>Oct 12, 2023</td>
                                    <td><span class="badge bg-success rounded-pill px-3">Active</span></td>
                                    <td>
                                        <button class="btn btn-sm btn-light text-primary"><i class="fas fa-eye"></i></button>
                                        <button class="btn btn-sm btn-light text-danger"><i class="fas fa-trash"></i></button>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="fw-bold">#ST1002</td>
                                    <td>Jane Smith</td>
                                    <td>Mechanical Eng.</td>
                                    <td>Oct 11, 2023</td>
                                    <td><span class="badge bg-warning text-dark rounded-pill px-3">Pending</span></td>
                                    <td>
                                        <button class="btn btn-sm btn-light text-primary"><i class="fas fa-eye"></i></button>
                                        <button class="btn btn-sm btn-light text-danger"><i class="fas fa-trash"></i></button>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="fw-bold">#ST1003</td>
                                    <td>Robert Brown</td>
                                    <td>Business Admin.</td>
                                    <td>Oct 10, 2023</td>
                                    <td><span class="badge bg-success rounded-pill px-3">Active</span></td>
                                    <td>
                                        <button class="btn btn-sm btn-light text-primary"><i class="fas fa-eye"></i></button>
                                        <button class="btn btn-sm btn-light text-danger"><i class="fas fa-trash"></i></button>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap 5 JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
